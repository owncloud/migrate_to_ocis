# Copy to .env to override defaults for a local run.

# Image tags (pin exact versions for reproducibility).
OC10_TAG=10.15
OCIS_TAG=7.1.0
MARIADB_TAG=10.11
REDIS_TAG=6

# Credentials.
OC10_ADMIN=admin
OC10_PW=admin
OCIS_ADMIN=admin
OCIS_PW=admin

# How OC10 / the migration reaches oCIS (docker-network address).
OCIS_HOST=ocis:9200

# Dev-loop toggles (1 = run the phase, 0 = skip).
RUN_UP=1
RUN_SEED=1
RUN_MIGRATE=1
RUN_ASSERT=1

# Leave containers running after the suite (for debugging / re-running asserts).
KEEP_UP=0
